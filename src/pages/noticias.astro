---
import LegacyPage from '../components/LegacyPage.astro';
import NewsSection from '../components/NewsSection.astro';


const afterFooterHtml = ``;
---

<LegacyPage
  title="Noticias ECAM Forum | Actualidad del mercado audiovisual"
  lang="es"
  description="Consulta las últimas noticias de ECAM Forum: proyectos seleccionados, invitados internacionales y novedades del sector audiovisual."
  ogTitle="Noticias ECAM Forum | Novedades de cine e industria"
  ogDescription="Toda la actualidad de ECAM Forum sobre proyectos, convocatorias e invitados de la industria audiovisual."
  ogUrl="https://ecamforum.es/noticias"
  ogImage="https://ecamforum.es/images/forum-share.jpg"
  loadLegacyInteractive={false}
  loadModernInteractive={true}
  pageId="news"
  currentRoute="/noticias"
  counterpartRoute="/en/news"
  footerLocale="es"
  hasLegacyProjectModal={false}
  hasProject2025Modal={false}
  hasNewsModal={true}
  hasSeminarModal={false}
  afterFooterHtml={afterFooterHtml}
>
  <NewsSection lang={"es"} pageId={"news"} />
</LegacyPage>
