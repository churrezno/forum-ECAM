---
import LegacyPage from '../components/LegacyPage.astro';
import SeminarsSection from '../components/SeminarsSection.astro';


const afterFooterHtml = ``;
---

<LegacyPage
  title="Actividades ECAM Forum | Seminarios y conversaciones de industria"
  lang="es"
  description="Descubre las actividades de ECAM Forum: seminarios, conversaciones y sesiones para profesionales del cine y la industria audiovisual."
  ogTitle="Actividades ECAM Forum | Seminarios y charlas audiovisuales"
  ogDescription="Programa de actividades de ECAM Forum con ponencias, encuentros profesionales y sesiones de industria."
  ogUrl="https://ecamforum.es/actividades"
  ogImage="https://ecamforum.es/images/forum-share.jpg"
  loadLegacyInteractive={true}
  loadModernInteractive={false}
  pageId="activities"
  currentRoute="/actividades"
  counterpartRoute="/en/"
  footerLocale="es"
  hasLegacyProjectModal={false}
  hasProject2025Modal={false}
  hasNewsModal={false}
  hasSeminarModal={true}
  afterFooterHtml={afterFooterHtml}
>
  <SeminarsSection lang={"es"} pageId={"activities"} />
</LegacyPage>
