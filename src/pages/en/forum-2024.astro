---
import LegacyPage from '../../components/LegacyPage.astro';
import ProjectsSection from '../../components/ProjectsSection.astro';
import VideoSection from '../../components/VideoSection.astro';
import SponsorsSection from '../../components/SponsorsSection.astro';
import segment0Html from '../../legacy/en__forum-2024.segment-0.html?raw';
import afterFooterHtml from '../../legacy/en__forum-2024.after-footer.html?raw';
---

<LegacyPage
  title="ECAM Forum 2025"
  lang="en"
  description="Forum 2025"
  ogTitle="ECAM Forum"
  ogDescription="2025"
  ogUrl="https://ecamforum.es/"
  ogImage="https://ecamforum.es/images/forum-share.jpg"
  loadLegacyInteractive={true}
  loadModernInteractive={false}
  pageId="forum-2024"
  currentRoute="/en/forum-2024"
  counterpartRoute="/forum-2024"
  footerLocale="en"
  hasLegacyProjectModal={true}
  hasProject2025Modal={false}
  hasNewsModal={false}
  hasSeminarModal={false}
  afterFooterHtml={afterFooterHtml}
>
  <ProjectsSection lang={"en"} pageId={"forum-2024"} />
  <Fragment set:html={segment0Html} />
  <VideoSection lang={"en"} pageId={"forum-2024"} />
  <SponsorsSection lang={"en"} />
</LegacyPage>
