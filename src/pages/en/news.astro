---
import LegacyPage from '../../components/LegacyPage.astro';
import NewsSection from '../../components/NewsSection.astro';


const afterFooterHtml = ``;
---

<LegacyPage
  title="ECAM Forum News | International Film Industry Updates"
  lang="en"
  description="Read the latest ECAM Forum news, including selected projects, international guests, and updates from the audiovisual industry."
  ogTitle="ECAM Forum News | Film and audiovisual updates"
  ogDescription="Stay informed with ECAM Forum announcements, project news, and international market updates."
  ogUrl="https://ecamforum.es/en/news"
  ogImage="https://ecamforum.es/images/forum-share.jpg"
  loadLegacyInteractive={false}
  loadModernInteractive={true}
  pageId="news"
  currentRoute="/en/news"
  counterpartRoute="/noticias"
  footerLocale="es"
  hasLegacyProjectModal={false}
  hasProject2025Modal={false}
  hasNewsModal={true}
  hasSeminarModal={false}
  afterFooterHtml={afterFooterHtml}
>
  <NewsSection lang={"en"} pageId={"news"} />
</LegacyPage>
