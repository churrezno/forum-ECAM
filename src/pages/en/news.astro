---
import LegacyPage from '../../components/LegacyPage.astro';
import beforeHtml from '../../legacy/en__news.before.html?raw';
import newsHtml from '../../legacy/en__news.news.html?raw';
import afterHtml from '../../legacy/en__news.after.html?raw';
import afterFooterHtml from '../../legacy/en__news.after-footer.html?raw';
---

<LegacyPage
  title="ECAM Forum 2025"
  lang="en"
  description="Forum 2025"
  ogTitle="ECAM Forum"
  ogDescription="2025"
  ogUrl="https://ecamforum.es/"
  ogImage="https://ecamforum.es/images/forum-share.jpg"
  loadLegacyInteractive={false}
  loadModernInteractive={true}
  pageId="news"
  currentRoute="/en/news"
  counterpartRoute="/noticias"
  footerLocale="es"
  hasLegacyProjectModal={false}
  hasProject2025Modal={false}
  hasNewsModal={true}
  hasSeminarModal={false}
  beforeHtml={beforeHtml}
  newsHtml={newsHtml}
  afterHtml={afterHtml}
  afterFooterHtml={afterFooterHtml}
/>
