---
import LegacyPage from '../../components/LegacyPage.astro';
import NewsSection from '../../components/NewsSection.astro';
import VideoSection from '../../components/VideoSection.astro';
import SponsorsSection from '../../components/SponsorsSection.astro';
import segment0Html from '../../legacy/en__index.segment-0.html?raw';
import afterFooterHtml from '../../legacy/en__index.after-footer.html?raw';
---

<LegacyPage
  title="ECAM Forum 2025"
  lang="en"
  description="Forum 2025"
  ogTitle="ECAM Forum"
  ogDescription="2025"
  ogUrl="https://ecamforum.es/en"
  ogImage="https://ecamforum.es/images/forum-share.jpg"
  loadLegacyInteractive={false}
  loadModernInteractive={true}
  pageId="home"
  currentRoute="/en/"
  counterpartRoute="/"
  footerLocale="en"
  hasLegacyProjectModal={false}
  hasProject2025Modal={false}
  hasNewsModal={true}
  hasSeminarModal={false}
  afterFooterHtml={afterFooterHtml}
>
  <Fragment set:html={segment0Html} />
  <NewsSection lang={"en"} pageId={"home"} />
  <VideoSection lang={"en"} pageId={"home"} />
  <SponsorsSection lang={"en"} />
</LegacyPage>
