---
import LegacyPage from '../components/LegacyPage.astro';
import beforeHtml from '../legacy/politica-privacidad.before.html?raw';

import afterHtml from '../legacy/politica-privacidad.after.html?raw';
import afterFooterHtml from '../legacy/politica-privacidad.after-footer.html?raw';
---

<LegacyPage
  title="ECAM Forum 2025"
  lang="es"
  description="Forum 2025"
  ogTitle="ECAM Forum"
  ogDescription="2025"
  ogUrl="https://ecamforum.es/"
  ogImage="https://ecamforum.es/images/forum-share.jpg"
  loadLegacyInteractive={false}
  loadModernInteractive={false}
  pageId="legal"
  currentRoute="/politica-privacidad"
  counterpartRoute="/en/"
  footerLocale="es"
  hasLegacyProjectModal={false}
  hasProject2025Modal={false}
  hasNewsModal={false}
  hasSeminarModal={false}
  beforeHtml={beforeHtml}

  afterHtml={afterHtml}
  afterFooterHtml={afterFooterHtml}
/>
