---
import LegacyPage from '../components/LegacyPage.astro';
import ProjectsSection from '../components/ProjectsSection.astro';
import VideoSection from '../components/VideoSection.astro';
import SponsorsSection from '../components/SponsorsSection.astro';
import segment0Html from '../legacy/forum-2025.segment-0.html?raw';
import segment1Html from '../legacy/forum-2025.segment-1.html?raw';
import afterFooterHtml from '../legacy/forum-2025.after-footer.html?raw';
---

<LegacyPage
  title="ECAM Forum 2025"
  lang="es"
  description="Forum 2025"
  ogTitle="ECAM Forum"
  ogDescription="2025"
  ogUrl="https://ecamforum.es/"
  ogImage="https://ecamforum.es/images/forum-share.jpg"
  loadLegacyInteractive={true}
  loadModernInteractive={true}
  pageId="forum-2025"
  currentRoute="/forum-2025"
  counterpartRoute="/en/forum-2025"
  footerLocale="es"
  hasLegacyProjectModal={false}
  hasProject2025Modal={true}
  hasNewsModal={false}
  hasSeminarModal={true}
  afterFooterHtml={afterFooterHtml}
>
  <Fragment set:html={segment0Html} />
  <ProjectsSection lang={"es"} pageId={"forum-2025"} />
  <Fragment set:html={segment1Html} />
  <VideoSection lang={"es"} pageId={"forum-2025"} />
  <SponsorsSection lang={"es"} />
</LegacyPage>
