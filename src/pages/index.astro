import SponsorsSection from '../components/SponsorsSection.astro';
const basePath = import.meta.env.BASE_URL;

const segment0Html = `    
    <section id="about">
        <div class="container">
            <div class="row">
                <div class="col col-md-8">
                    <h3 class="tit-seccion rojo">ABOUT</h3>
                    <p>ECAM FORUM es un foro de coproducción internacional que busca convertirse en una plataforma esencial para el impulso del sector audiovisual español, tendiendo puentes entre la industria audiovisual nacional e internacional, y conectando el mejor talento con una importante delegación de representantes internacionales de la industria audiovisual.</p>
                    <p>Un evento de industria que cuenta con cuatro secciones para presentar proyectos (<em>Films to Come</em> - largometrajes desarrollo, <em>Last Push</em> - largometrajes posproducción, <em>Forum Shorts</em> - cortometrajes y <em>ECAM Series Market</em> - series) así como una agenda de talleres y charlas de industria <em>(Industry Talks)</em> un espacio de conversaciones y pensamiento multidisciplinar <em>(El Estado de las Cosas)</em> y un foro de inversión y financiación para el cine independiente <em>(FINDE).</em></p>
                    <p>En apenas dos ediciones, ECAM FORUM se ha consolidado como un nuevo foro internacional de coproducción clave en España reconocido por reunir proyectos de alto nivel y atraer a invitados de gran prestigio.  </p>
                    <p>ECAM FORUM ha conseguido atraer a directores artísticos y programadores de festivales internacionales como Cannes, Venecia, Berlinale, Sundance, Locarno, Rotterdam, Toronto, San Sebastián, New York Film Festival, MoMA, Marrakech, Thessaloniki, Zurich o Series Manía, agentes de ventas como Coproduction Office, Goodfellas, Mk2, Le Pacte, Memento, Films Boutique o Alpha Violet, mercados como Les Arcs, MIA Market, MAFIZ, BAM Bogotá o Cinemart, y productoras independientes de referencia de Francia, Italia, Suecia, Bélgica, EEUU, Portugal, Austria, Alemania, Grecia, Argentina, Uruguay entre otros.</p>
                    <p>Las películas presentadas en ECAM Forum han logrado en tan solo dos años estrenos en Venecia, TIFF Toronto, Locarno, Rotterdam, San Sebastián, Sitges o FID Marsella y un recorrido en festivales como Chicago, Indielisboa, Karlovy Vary, Festival de Málaga, BFI Londres, Les Arcs, Tesalónica, AFI Fest Los Ángeles, Transilvania, Palms Springs o Vancouver, entre las que destacan <em>Los Tortuga</em> de <strong>Belén Funes</strong> (TIFF Toronto 2024), <em>Milkteeth</em> de <strong>Mihai Mincan</strong> (Venecia 2025), <em>Anoché Conquiste Tebas</em> de <strong>Gabriel Azorín</strong> (Giornate Venecia 2025), <em>Balearic</em> de <strong>Ion de Sosa</strong> (Locarno 2025), <em>Deuses de Pedra</em> de <strong>Ivan Castiñeiras</strong> (IFFR Roterdam 2025), <em>Ariel</em> de <strong>Lois Patiño</strong> (IFFR Roterdam 2025), <em>Hanami</em> de <strong>Denise Fernandes</strong> (Locarno 2024), <em>Aro Berria</em> de <strong>Irati Gorostidi</strong> (San Sebastián 2025). </p>
                </div>
            </div>
        </div>
    </section>
    
    <section id="finde" class="bg-azul">
        <div class="container">
            <div class="row mb-4">
                <div class="col-12 col-md-8">
                    <img class="logo-finde" src="${basePath}images/logo-FINDE.svg" alt="FINDE">
                    <p class="blanco"><strong>Encuentro de Financiación, Inversión y Cine Independiente de Madrid</strong> nació en 2025 impulsado por la ECAM y el Clúster Audiovisual de Madrid con el objetivo estratégico de conectar al sector del cine independiente y nuevos modelos de financiación e inversión. FINDE quiere tender puentes, además de <strong>dotar a los productores de herramientas concretas para explorar nuevos modelos financieros y facilitar un entendimiento mutuo entre inversores y creadores.</strong> A lo largo de dos días combina formaciones especializadas sobre inversión privada y equity, presentaciones de fondos internacionales, encuentros entre fondos, inversores, productoras independientes y agentes del sector.</p>
                    <p class="blanco">La primera edición contó con la presencia de algunos de los inversores más importantes del panorama europeo enfocados en financiar cine independiente como Together Fund o Logical Pictures además de representantes como Rémi Burah (director general de ARTE/Cofinova), Giorgos Karnavas (CEO y fundador de Heretic) o Sophie Erbs (productora y fundadora de Gaijin). Además contó con la presencia de María González Veracruz - Secretaría de Estado de Digitalización e Inteligencia Artificial, María Coronado de la SETT Sociedad Española para la Transformación Tecnológica, así como representantes de Comunidad de Madrid y Ayuntamiento de Madrid.</p>
                </div>
                <div class="col-12 col-md-4 bkg">
                </div>
            </div>
            
            <div class="row">
                <div class="col-12 col-md-4 mb-2">
                    <img src="${basePath}images/finde-1.jpg" alt="FINDE">
                </div>
                <div class="col-12 col-md-4 mb-2">
                    <img src="${basePath}images/finde-2.jpg" alt="FINDE">
                </div>
                <div class="col-12 col-md-4 mb-2">
                    <img src="${basePath}images/finde-4.jpg" alt="FINDE">
                </div>
            </div>
        </div>
    </section>`;
