---
import LegacyPage from '../components/LegacyPage.astro';
import beforeHtml from '../legacy/index.before.html?raw';
import projectsHtml from '../legacy/index.projects.html?raw';
import newsHtml from '../legacy/index.news.html?raw';
import afterHtml from '../legacy/index.after.html?raw';
import afterFooterHtml from '../legacy/index.after-footer.html?raw';
---

<LegacyPage
  title="ECAM Forum 2025"
  lang="es"
  description="Forum 2025"
  ogTitle="ECAM Forum"
  ogDescription="2025"
  ogUrl="https://ecamforum.es/"
  ogImage="https://ecamforum.es/images/forum-share.jpg"
  loadLegacyInteractive={false}
  loadModernInteractive={true}
  pageId="home"
  currentRoute="/"
  counterpartRoute="/en/"
  footerLocale="es"
  hasLegacyProjectModal={false}
  hasProject2025Modal={false}
  hasNewsModal={true}
  hasSeminarModal={false}
  beforeHtml={beforeHtml}
  projectsHtml={projectsHtml}
  newsHtml={newsHtml}
  afterHtml={afterHtml}
  afterFooterHtml={afterFooterHtml}
/>
