---
import '../scss/app.scss';

interface Props {
  title: string;
  lang?: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogUrl?: string;
  ogImage?: string;
  loadLegacyInteractive?: boolean;
  loadModernInteractive?: boolean;
}

const {
  title,
  lang = 'es',
  description = 'Forum 2025',
  ogTitle = 'ECAM Forum',
  ogDescription = '2025',
  ogUrl = 'https://ecamforum.es/',
  ogImage = 'https://ecamforum.es/images/forum-share.jpg',
  loadLegacyInteractive = false,
  loadModernInteractive = false,
} = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="author" content="ECAM" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="keywords" content="ECAM, Forum" />
    <title>{title}</title>

    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:image" content={ogImage} />

    <link rel="stylesheet" href="/vendor/cookienoticepro.style.css?v=1.0.1" />
  </head>
  <body>
    <slot />
    <script>
      import '../js/site.js';
    </script>
    {loadLegacyInteractive && (
      <script>
        import '../js/scripts.js';
      </script>
    )}
    {loadModernInteractive && (
      <script>
        import '../js/scripts-2025.js';
      </script>
    )}
  </body>
</html>
