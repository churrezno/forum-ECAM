---
import '../scss/app.scss';

interface Props {
  title: string;
  lang?: string;
  description?: string;
  keywords?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogUrl?: string;
  ogImage?: string;
  currentRoute?: string;
  counterpartRoute?: string;
  loadLegacyInteractive?: boolean;
  loadModernInteractive?: boolean;
}

const {
  title,
  lang = 'es',
  description = 'ECAM Forum: mercado internacional de coproducción y encuentro de industria audiovisual en Madrid.',
  keywords,
  ogTitle,
  ogDescription,
  ogUrl = 'https://ecamforum.es/',
  ogImage = 'https://ecamforum.es/images/forum-share.jpg',
  currentRoute = '/',
  counterpartRoute = '/en/',
  loadLegacyInteractive = false,
  loadModernInteractive = false,
} = Astro.props;
const siteUrl = 'https://ecamforum.es';
const basePath = import.meta.env.BASE_URL;
const canonicalUrl = new URL(currentRoute, siteUrl).toString();
const alternateUrl = new URL(counterpartRoute, siteUrl).toString();
const xDefaultUrl = new URL(lang === 'en' ? counterpartRoute : currentRoute, siteUrl).toString();
const ogLocale = lang === 'en' ? 'en_GB' : 'es_ES';
const ogLocaleAlternate = lang === 'en' ? 'es_ES' : 'en_GB';
const resolvedOgTitle = ogTitle ?? title;
const resolvedOgDescription = ogDescription ?? description;
const resolvedKeywords =
  keywords ??
  (lang === 'en'
    ? 'ECAM Forum, international co-production market, audiovisual industry, film projects, Madrid'
    : 'ECAM Forum, mercado internacional de coproducción, industria audiovisual, proyectos de cine, Madrid');
const ogImageAlt = lang === 'en' ? `Poster image for ${title}` : `Imagen promocional de ${title}`;
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'ECAM Forum',
  url: siteUrl,
  logo: `${siteUrl}/images/logo_FORUM_ECAM.svg`,
  sameAs: [
    'https://es-la.facebook.com/ECAMescuela/',
    'https://twitter.com/ecam_',
    'https://www.instagram.com/ecam_cine/',
    'https://www.linkedin.com/company/ecam-escuela-de-cinematograf-a-y-del-audiovisual-de-la-comunidad-de-madrid-/',
    'https://www.youtube.com/channel/UCkpBkvGs-zX6ayayKNhY5bw',
  ],
};
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'ECAM Forum',
  url: siteUrl,
  inLanguage: lang === 'en' ? 'en' : 'es',
};
const structuredData = JSON.stringify([organizationSchema, websiteSchema]);
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="author" content="ECAM" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="keywords" content={resolvedKeywords} />
    <meta name="theme-color" content="#0f2345" />
    <title>{title}</title>

    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={lang} href={canonicalUrl} />
    <link rel="alternate" hreflang={lang === 'en' ? 'es' : 'en'} href={alternateUrl} />
    <link rel="alternate" hreflang="x-default" href={xDefaultUrl} />
    <link rel="icon" href={`${basePath}favicon.ico`} sizes="any" />

    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={new URL(ogUrl, siteUrl).toString()} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:site_name" content="ECAM Forum" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlternate} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedOgTitle} />
    <meta name="twitter:description" content={resolvedOgDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:url" content={canonicalUrl} />
    <script type="application/ld+json" set:html={structuredData}></script>

    <link rel="stylesheet" href={`${basePath}vendor/cookienoticepro.style.css?v=1.0.1`} />
  </head>
  <body>
    <slot />
    <script>
      import '../js/site.js';
    </script>
    {loadLegacyInteractive && (
      <script>
        import '../js/scripts.js';
      </script>
    )}
    {loadModernInteractive && (
      <script>
        import '../js/scripts-2025.js';
      </script>
    )}
  </body>
</html>
