---
import { seminarsData as seminarsData2025 } from '../js/data-seminarios-2025.js';
import { seminarsData as seminarsData2026 } from '../js/data-seminarios-2026.js';

interface SeminarCard {
  seminar: string;
  cardClass: string;
  type: string;
  typeClass?: string;
  lead: string;
  leadClass: string;
  imageSrc: string;
  imageAlt: string;
  title?: string;
  titleClass?: string;
  dateLabel: string;
  dateClass: string;
  locationHtml: string;
  locationClass: string;
  collaboratorLabel?: string;
  collaboratorLabelClass?: string;
  collaboratorSrc?: string;
  collaboratorAlt?: string;
  collaboratorLogoClass?: string;
  showTitleOnCard: boolean;
}

interface SeminarGroup {
  titleEs: string;
  titleEn: string;
  marginTopClass?: string;
  items: SeminarCard[];
}

interface Props {
  lang?: 'es' | 'en';
  year?: number;
}

const { lang = 'es', year = 2025 } = Astro.props;
const basePath = import.meta.env.BASE_URL;
const isEnglish = lang === 'en';

const seminarsData = year === 2026 ? seminarsData2026 : seminarsData2025;

const groupsConfig: Record<number, Record<string, { titleEs: string; titleEn: string; marginTopClass?: string }>> = {
  2025: {
    'Conversaciones. El estado de las cosas': { titleEs: 'CONVERSACIONES', titleEn: 'CONVERSATIONS' },
    'Industry Talks': { titleEs: 'INDUSTRY TALKS', titleEn: 'INDUSTRY TALKS', marginTopClass: 'mt-5' },
    'Foco Bertrand Bonello': { titleEs: 'SEMINARIO & PROYECCIONES', titleEn: 'SEMINAR & PROJECTIONS', marginTopClass: 'mt-5' },
  },
  2026: {
    'Conversaciones. El estado de las cosas': { titleEs: 'CONVERSACIONES', titleEn: 'CONVERSATIONS' },
    'Industry Talks': { titleEs: 'INDUSTRY TALKS', titleEn: 'INDUSTRY TALKS', marginTopClass: 'mt-5' },
    'Foco Bertrand Bonello': { titleEs: 'SEMINARIO & PROYECCIONES', titleEn: 'SEMINAR & PROJECTIONS', marginTopClass: 'mt-5' },
  }
};

const config = groupsConfig[year] || groupsConfig[2025];

const groupedItems = seminarsData.reduce((acc, item) => {
  const groupKey = item.activity;
  if (!acc[groupKey]) {
    acc[groupKey] = [];
  }
  acc[groupKey].push(item);
  return acc;
}, {} as Record<string, typeof seminarsData>);

const formatTimeLabel = (dateStr: string, timeStr: string): string => {
  const date = new Date(dateStr);
  const day = String(date.getDate()).padStart(2, '0');
  const monthKey = date.toLocaleDateString(isEnglish ? 'en-US' : 'es-ES', { month: 'short' }).toUpperCase().replace('.', '');
  const timeParts = timeStr.match(/^(\d{2}):(\d{2})/);
  const hour = timeParts ? timeParts[1] : '18';
  return `${day} ${monthKey}/${hour} H.`;
};

const getCollaboratorLogo = (activity: string, colaboratorUrl: string | undefined): string | undefined => {
  if (!colaboratorUrl || colaboratorUrl === '-') return undefined;
  if (activity.includes('Foco Bertrand Bonello')) {
    return '/images/logos-colaboradores_bonello-cuadrado.svg';
  }
  if (colaboratorUrl.includes('dama')) {
    return '/images/logo-dama_rojo.svg';
  }
  return `/images/${colaboratorUrl}`;
};

const groups: SeminarGroup[] = Object.entries(config).map(([activity, groupConfig]) => {
  const items = groupedItems[activity] || [];
  return {
    ...groupConfig,
    items: items.map((item): SeminarCard => {
      const isConversaciones = item.activity.includes('Conversaciones');
      const isIndustry = item.activity.includes('Industry');
      const isFoco = item.activity.includes('Foco');

      const cardClass = isConversaciones ? 'bg-azul' : isIndustry ? 'bg-rojo' : 'bg-gris';
      const leadClass = isConversaciones ? 'rojo' : 'azul';
      const dateClass = leadClass;
      const locationClass = leadClass;
      const typeClass = isFoco ? 'rojo' : undefined;
      const showTitleOnCard = !isIndustry && item.subtitle && item.subtitle !== '-' && !isFoco;

      const dateLabel = formatTimeLabel(item.date, item.time);
      const locationParts = item.location.split(' - ');
      const locationHtml = locationParts.join('<br>');

      const subtitleText = isEnglish && item.subtitleEn && item.subtitleEn !== '-' ? item.subtitleEn : item.subtitle;
      const cardTitle = showTitleOnCard ? subtitleText : undefined;

      const collaboratorLogo = getCollaboratorLogo(item.activity, item.colaboratorUrl);

      return {
        seminar: item.seminar,
        cardClass,
        type: item.activity,
        typeClass,
        lead: item.title,
        leadClass,
        imageSrc: `/images/${item.photoUrl}`,
        imageAlt: item.subtitle || item.title,
        title: cardTitle,
        titleClass: 'titulo',
        dateLabel,
        dateClass,
        locationHtml,
        locationClass,
        collaboratorLabel: item.colaborator && item.colaborator !== '-' ? (isEnglish ? 'In collaboration with' : 'En colaboración con') : undefined,
        collaboratorLabelClass: leadClass,
        collaboratorSrc: collaboratorLogo,
        collaboratorAlt: item.colaborator || 'Colaborador',
        collaboratorLogoClass: 'logo-colaborador',
        showTitleOnCard,
      };
    }),
  };
}).filter(group => group.items.length > 0);

const sectionTitle = isEnglish ? 'ACTIVITIES' : 'ACTIVIDADES';
---

<section id="seminarios" data-year={year}>
  <div class="container">
    <div class="row row-intro">
      <div class="col-12">
        <h3 class="tit-seccion rojo">{sectionTitle}</h3>
      </div>
    </div>

    {groups.map((group) => (
      <div class="row">
        <h4 class:list={['subtit-seccion', 'azul', 'mb-2', group.marginTopClass]}>{isEnglish ? group.titleEn : group.titleEs}</h4>
        {group.items.map((item) => (
          <div class="col-12 col-md-6">
            <a href="#" data-bs-toggle="modal" data-bs-target="#modalSeminario" data-seminar={item.seminar}>
              <div class:list={['wrapper-evento', item.cardClass]}>
                <p class:list={['tipo-evento', item.typeClass]}>{item.type}</p>
                <div class:list={['ponente_name', item.leadClass]}>{item.lead}</div>
                <img src={`${basePath}${item.imageSrc.replace(/^\//, '')}`} alt={item.imageAlt} class="ponente_img" />
                {item.title && <div class:list={[item.titleClass]}>{item.title}</div>}
                <div class:list={['fecha', item.dateClass]}>{item.dateLabel}</div>
                <div class="wrapper-cierre">
                  <div class:list={[item.locationClass]} set:html={item.locationHtml}></div>
                  {item.collaboratorSrc && (
                    <div class="wrapper-colaborador">
                      {item.collaboratorLabel && <p class:list={[item.collaboratorLabelClass, 'mb-0']}>{item.collaboratorLabel}</p>}
                      <img
                        src={`${basePath}${item.collaboratorSrc.replace(/^\//, '')}`}
                        alt={item.collaboratorAlt ?? 'Colaborador'}
                        class={item.collaboratorLogoClass ?? 'logo-colaborador'}
                      />
                    </div>
                  )}
                </div>
              </div>
            </a>
          </div>
        ))}
      </div>
    ))}
  </div>
</section>