---
import Footer from './Footer.astro';
import Header from './Header.astro';
import NewsModal from './modals/NewsModal.astro';
import ProjectModal2025 from './modals/ProjectModal2025.astro';
import ProjectModalLegacy from './modals/ProjectModalLegacy.astro';
import SeminarModal from './modals/SeminarModal.astro';
import LegacyLayout from '../layouts/LegacyLayout.astro';

interface Props {
  title: string;
  lang?: 'es' | 'en';
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogUrl?: string;
  ogImage?: string;
  loadLegacyInteractive?: boolean;
  loadModernInteractive?: boolean;
  pageId: 'home' | 'forum-2024' | 'forum-2025' | 'news' | 'activities' | 'legal';
  currentRoute: string;
  counterpartRoute: string;
  footerLocale?: 'es' | 'en';
  hasLegacyProjectModal?: boolean;
  hasProject2025Modal?: boolean;
  hasNewsModal?: boolean;
  hasSeminarModal?: boolean;
  afterFooterHtml?: string;
}

const props = Astro.props;
---

<LegacyLayout
  title={props.title}
  lang={props.lang}
  description={props.description}
  ogTitle={props.ogTitle}
  ogDescription={props.ogDescription}
  ogUrl={props.ogUrl}
  ogImage={props.ogImage}
  currentRoute={props.currentRoute}
  counterpartRoute={props.counterpartRoute}
  loadLegacyInteractive={props.loadLegacyInteractive}
  loadModernInteractive={props.loadModernInteractive}
>
  <a class="skip-link" href="#main-content">
    {props.lang === 'en' ? 'Skip to main content' : 'Saltar al contenido principal'}
  </a>
  <Header
    locale={props.lang ?? 'es'}
    pageId={props.pageId}
    currentRoute={props.currentRoute}
    counterpartRoute={props.counterpartRoute}
  />
  <main id="main-content"><slot /></main>
  <Footer locale={props.footerLocale ?? props.lang ?? 'es'} />
  {props.hasLegacyProjectModal && <ProjectModalLegacy />}
  {props.hasProject2025Modal && <ProjectModal2025 />}
  {props.hasNewsModal && <NewsModal />}
  {props.hasSeminarModal && <SeminarModal />}
  {props.afterFooterHtml && <Fragment set:html={props.afterFooterHtml} />}
</LegacyLayout>
