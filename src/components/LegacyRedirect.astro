---
interface Props {
  to: string;
}

const { to } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${to}`} />
    <link rel="canonical" href={to} />
    <script is:inline>
      window.location.replace({JSON.stringify(to)});
    </script>
    <title>Redirecting...</title>
  </head>
  <body>
    <a href={to}>Redirecting...</a>
  </body>
</html>
