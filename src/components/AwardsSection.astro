        </div>
      </div>

      {content.groups.map((group, index) => (
        <div class:list={["row", index > 0 && "mt-5"]}>
          <div class="col-12">
            <h4 class="tit-categoria azul">
              {group.title}
              <svg viewBox="0 0 66 59" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d={arrowPath} fill={arrowFill} />
              </svg>
            </h4>
          </div>
          {group.items.map((item) => (
            <div class="col-12 col-md-4">
              <p class="premio">{item.prize}</p>
              <p class="proyecto-titulo azul">{item.project}</p>
              <p class="azul">{item.description}</p>
            </div>
          ))}
        </div>
      ))}
    </div>
