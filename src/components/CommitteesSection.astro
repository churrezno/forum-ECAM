const content = committeesByPage[`${pageId}:${lang}`];
---

{content && (
  <section id="comites" class="bg-blanco">
    <div class="container">
      <div class="row">
        <div class="col col-md-8 mb-5">
          <h3 class="tit-seccion rojo">{content.title}</h3>
        </div>
      </div>

      {content.groups.map((group, index) => (
        <div class:list={["row", index > 0 && "mt-4"]}>
          <div class="col-12">
            <h4 class:list={["tit-categoria", group.color]}>{group.title}</h4>
          </div>
          {group.people.map((person) => (
            <div class="col-6 col-md-3">
              <img src={`${basePath}images/comites/${person.image}`} alt={`${person.name} - ${person.role}`} />
              <p class="nombre azul">{person.name}</p>
              <p class="azul">{person.role}</p>
            </div>
          ))}
        </div>
      ))}
    </div>
  </section>
)}
